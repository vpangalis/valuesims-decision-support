flowchart TD

  HTML[index.html 5-panel SPA]
  JS[cosolve-ui.js caseState hydrateCase sendFullEnvelope submitAiQuestion]
  HTML --> JS

  FASTAPI[FastAPI backend app.py BackendApp BackendContainer]

  R_CASE[POST entry case]
  R_REASON[POST entry reasoning]
  R_KNOW[POST entry knowledge]
  R_SUGG[POST entry suggestions]
  R_SEARCH[POST cases search]
  R_KPI[GET cases kpi KPITool global scope]
  R_GET[GET cases by id]
  R_EVIDENCE[GET cases evidence]
  R_KLIST[GET knowledge]
  R_KFILE[GET knowledge file]
  R_KDEL[DELETE knowledge file]

  EH[EntryHandler handle_entry]
  EH_CASE[handle_case_ingestion CREATE UPDATE CLOSE UPLOAD]
  EH_AI[handle_ai_reasoning]
  EH_SUGG[generate_suggestions 6 chips]

  CES[CaseEntryService create load patch save merge]
  CIS[CaseIngestionService index case]
  CSI[CaseSearchIndex upload merge_or_upload]
  EIS[EvidenceIngestionService]
  KIS[KnowledgeIngestionService chunk 12000 chars PDF extract]

  N_START[StartNode reset escalation flags]
  N_CTX[ContextNode load case detect D-state]
  N_CLS[IntentClassificationNode OPERATIONAL or SIMILARITY or STRATEGY or KPI]
  N_QR[QuestionReadinessNode READY or NOT_READY]
  N_RT[RouterNode route by intent]
  N_OP[OperationalNode 3-pass LLM reasoning OperationalPayload]
  N_OPR[OperationalReflectionNode ESCALATE or CONTINUE]
  N_OPE[OperationalEscalationNode premium model rerun]
  N_SIM[SimilarityNode precedent case search SimilarityPayload]
  N_SIMR[SimilarityReflectionNode validate findings]
  N_STR[StrategyNode portfolio pattern analysis StrategyPayload]
  N_STRR[StrategyReflectionNode ESCALATE or CONTINUE]
  N_STRE[StrategyEscalationNode premium model rerun]
  N_KPI[KPINode KPITool get_kpis KPIResult]
  N_KPIR[KPIReflectionNode interpret metrics]
  N_FMT[ResponseFormatterNode final_response citations chips]
  N_END[EndNode]

  EC[EscalationController should_escalate]
  MP[ModelPolicy resolve_model base or premium]
  LLMC[LoggedLanguageModelClient timing tokens llm_calls.jsonl]
  LMC[LanguageModelClient complete_json complete_text SDK or REST]

  HR[HybridRetriever retrieve_similar_cases retrieve_knowledge min_score 0.5 retrieve_evidence]
  CSC[CaseSearchClient hybrid_search BM25 plus vector text_search]
  ESC[EvidenceSearchClient search_by_case_id]
  KSC[KnowledgeSearchClient 2-stage small_chunks then parent sections]
  EMB[EmbeddingClient generate_embedding]

  BSC[BlobStorageClient upload download list delete]
  CR[CaseRepository create load save add_evidence]
  CRR[CaseReadRepository list_case_paths load_case]

  AZAI[Azure AI Search 3 indexes cases evidence knowledge]
  AZOAI[Azure OpenAI Foundry keys chat and embedding deployments]
  AZBLOB[Azure Blob Storage case.json evidence knowledge blobs]

  JS -->|POST entry case reasoning suggestions| R_CASE
  JS -->|POST cases search GET cases GET knowledge GET cases kpi| R_SEARCH

  FASTAPI --> R_CASE
  FASTAPI --> R_REASON
